generator client {
  provider   = "prisma-client"
  engineType = "client"
  runtime    = "bun"
  output     = "./generated"
}

datasource db {
  provider = "sqlite"
}

model ChatSession {
  id        String        @id @default(cuid())
  title     String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
}

model ChatMessage {
  id           String      @id @default(cuid())
  sessionId    String
  session      ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role         String      // "user" | "assistant" | "tool"
  content      String
  toolCallsJson String?    // JSON array of tool calls/results for this message
  createdAt    DateTime    @default(now())
}

model BackgroundJob {
  id        String   @id @default(cuid())
  command   String
  status    String   // "running" | "completed" | "failed"
  cwd       String
  pid       Int?
  logs      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Document {
  id        String      @id @default(cuid())
  folder    String
  title     String
  content   String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  stories   StoryCard[]

  @@index([folder])
}

enum StoryStatus {
  BACKLOG
  IN_PROGRESS
  IN_REVIEW
  DONE
  BLOCKED
  CANCELLED
}

model StoryCard {
  id         String      @id @default(cuid())
  title      String
  content    String      @default("")
  status     StoryStatus @default(BACKLOG)
  priority   String      @default("medium") // "urgent" | "high" | "medium" | "low"
  documentId String?
  document   Document?   @relation(fields: [documentId], references: [id], onDelete: SetNull)
  tags       String      @default("[]") // JSON array of tag strings
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  statusLogs StoryStatusLog[]

  @@index([status])
  @@index([documentId])
}

model StoryStatusLog {
  id         String       @id @default(cuid())
  cardId     String
  card       StoryCard    @relation(fields: [cardId], references: [id], onDelete: Cascade)
  fromStatus StoryStatus? // null means initial creation
  toStatus   StoryStatus
  createdAt  DateTime     @default(now())

  @@index([cardId])
}
